---
import StoreButtons from "./StoreButtons.astro";
import { site } from "../config";
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-background via-white to-white"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6 py-16 sm:py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <div
          class="inline-flex items-center gap-2 rounded-full bg-primary/20 px-3 py-1 text-xs font-medium text-secondary mb-6"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
          Ya disponible en iOS y Android
        </div>

        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-black"
        >
          <span
            class="inline-flex items-center justify-center bg-secondary overflow-hidden shadow-lg ring-1 ring-black/5 mx-auto lg:mx-0 h-20 w-20 sm:h-24 sm:w-24 lg:h-28 lg:w-28"
            style="border-radius: 22.37%"
          >
            <img
              src="/brand/logo.png"
              alt={site.name}
              class="h-3/5 w-3/5 object-contain"
              width="112"
              height="112"
            />
          </span>
          <span class="block text-secondary mt-4 text-3xl sm:text-4xl lg:text-5xl">{site.tagline}</span>
        </h1>

        <p class="mt-6 text-lg text-label max-w-xl mx-auto lg:mx-0">
          {site.description}
        </p>

        <div class="mt-10 flex justify-center lg:justify-start">
          <StoreButtons />
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <div
            class="absolute -inset-6 bg-gradient-to-tr from-primary/40 to-secondary-variant/30 blur-2xl rounded-full"
          >
          </div>
          <img
            src="/screenshots/app-show.png"
            alt="Vista previa de la app Bubl"
            class="relative w-[280px] sm:w-[320px] lg:w-[340px] h-auto drop-shadow-2xl"
            width="340"
            height="680"
          />
        </div>
      </div>
    </div>
  </div>
</section>
